# =============================================================================
# AEGIS AI — example environment (no real secrets; safe to commit)
# =============================================================================
# Copy to `.env` in the **repository root** or `backend/.env`. Load order:
# repo-root .env → backend/.env → cwd .env (later overrides). Never commit `.env`.
# =============================================================================

NODE_ENV=development
PORT=8787
FRONTEND_URL=http://localhost:5173

JWT_SECRET=change-me-to-a-long-random-string

# --- AI (all optional) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
HF_API_KEY=
HF_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# --- Telegram (optional) — bot token + your numeric chat ID ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_GROUP_ID=

# --- Email (optional) — Gmail: App Password (16 chars; spaces in .env are stripped automatically) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=AEGIS AI <noreply@aegis.local>

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Do not use "(contact: email)" — overpass-api.de returns HTTP 406 for that pattern.
OSM_USER_AGENT=AEGIS-AI-Healthcare-OS/1.0

# Optional: when Overpass returns no hospitals, try Google Places Nearby Search
GOOGLE_PLACES_API_KEY=

# Frontend: production API base with /api/ . Dev: leave empty (Vite proxy).
VITE_API_URL=
